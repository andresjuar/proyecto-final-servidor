{
    "compilerOptions": {
        "noImplicitAny": true,
        "target": "esnext",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "types": ["node"]
    },
    "include": ["./src/**/*.ts"],
    "exclude": ["node_modules", "./src/**/*.spec.ts"]
}
